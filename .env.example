# Security: Generate strong passwords with: openssl rand -base64 32
# CRITICAL: Never commit actual secrets to version control

# Neo4j Database Credentials
# Generate with: openssl rand -base64 32
NEO4J_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Grafana Admin Credentials
# Generate with: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
GRAFANA_ADMIN_USER=admin

# Optional: Ollama Models (leave empty if not using)
SKILLS_OLLAMA_MODEL=
OLLAMA_MODEL=
OLLAMA_CHAT_MODEL=
