# Security: Generate strong passwords with: openssl rand -base64 32
# CRITICAL: Never commit actual secrets to version control

# Neo4j Database Credentials
# Generate with: openssl rand -base64 32
NEO4J_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Grafana Admin Credentials
# Generate with: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
GRAFANA_ADMIN_USER=admin

# Production vector embeddings (BGE-M3 via Ollama on the host)
# Docker services reach the host Ollama daemon at host.docker.internal:11434
SKILLS_EMBEDDING_PROVIDER=ollama-bge-m3
SKILLS_OLLAMA_BASE_URL=http://host.docker.internal:11434
SKILLS_OLLAMA_MODEL=bge-m3:567m
SKILLS_EMBEDDING_DIMENSIONS=1024

# Optional: Ollama chat models (leave empty if not using)
OLLAMA_MODEL=
OLLAMA_CHAT_MODEL=
