[
  {
    "id": "JRN-01-direct-lookup-tdd",
    "description": "Agent resolves and loads a known promoted skill by canonical id.",
    "server": "fixture",
    "tags": [
      "direct_lookup",
      "baseline"
    ],
    "steps": [
      {
        "tool": "route_skill_query",
        "arguments": {
          "query": "tell me about tdd-practice"
        },
        "expect": {
          "status": "ok",
          "route": "direct_lookup",
          "resolved_skill_id": "skill:tdd-practice",
          "suggested_tool": "get_skill"
        },
        "expect_wire": {
          "omits_selection_trace": true,
          "requires_usage_selection_run_id": true
        }
      },
      {
        "tool": "resolve_skill",
        "arguments": {
          "name": "tdd-practice"
        },
        "expect": {
          "status": "ok",
          "skill_id": "skill:tdd-practice"
        }
      },
      {
        "tool": "get_skill",
        "arguments": {
          "skill_id": "skill:tdd-practice",
          "retrieval_unit_limit": 2
        },
        "expect": {
          "status": "ok",
          "skill_name": "tdd-practice"
        }
      }
    ]
  },
