[
  {
    "id": "JRN-01-direct-lookup-tdd",
    "description": "Agent resolves and loads a known promoted skill by canonical id.",
    "server": "fixture",
    "tags": ["direct_lookup", "baseline"],
    "steps": [
      {
        "tool": "route_skill_query",
        "arguments": { "query": "tell me about tdd-practice" },
        "expect": {
          "status": "ok",
          "route": "direct_lookup",
          "resolved_skill_id": "skill:tdd-practice",
          "suggested_tool": "get_skill"
        },
        "expect_selection_trace": {
          "tool": "route_skill_query",
          "query_intent": "direct_lookup",
          "requires_usage_event_id": true,
          "requires_evidence": true
        }
      },
      {
        "tool": "resolve_skill",
        "arguments": { "name": "tdd-practice" },
        "expect": {
          "status": "ok",
          "skill_id": "skill:tdd-practice"
        }
      },
      {
        "tool": "get_skill",
        "arguments": { "skill_id": "skill:tdd-practice", "retrieval_unit_limit": 2 },
        "expect": {
          "status": "ok",
          "skill_name": "tdd-practice"
        }
      }
    ]
  },
  {
    "id": "JRN-02-recommend-defect",
    "description": "Agent recommends tdd-practice for a failing-test-first defect fix.",
    "server": "fixture",
    "tags": ["recommendation", "near_neighbour"],
    "steps": [
      {
        "tool": "route_skill_query",
        "arguments": {
          "query": "Which skill should I use when fixing a defect with a failing test first?"
        },
        "expect": {
          "status": "ok",
          "route": "recommendation",
          "suggested_tool": "recommend_skills"
        },
        "expect_selection_trace": {
          "tool": "route_skill_query",
          "query_intent": "recommendation",
          "requires_usage_event_id": true
        }
      },
      {
        "tool": "recommend_skills",
        "arguments": {
          "query": "fixing a defect with a failing test first and executable expectations",
          "limit": 3,
          "token_budget": 120
        },
        "expect": {
          "status": "ok",
          "uncertain": false,
          "top_skill_id": "skill:tdd-practice",
          "excludes_skill_ids": ["skill:reflection-and-verification"]
        },
        "expect_selection_trace": {
          "tool": "recommend_skills",
          "query_intent": "recommendation",
          "requires_usage_event_id": true,
          "requires_rank": true,
          "requires_filter": true,
          "requires_evidence_anchor_ids": true
        }
      }
    ]
  },
  {
    "id": "JRN-03-abstention",
    "description": "Agent abstains when the query is out of domain.",
    "server": "fixture",
    "tags": ["abstention"],
    "steps": [
      {
        "tool": "route_skill_query",
        "arguments": { "query": "What is the weather in London tomorrow?" },
        "expect": {
          "status": "ok",
          "route": "recommendation",
          "resolved_skill_id": null
        },
        "expect_selection_trace": {
          "tool": "route_skill_query",
          "query_intent": "recommendation",
          "requires_usage_event_id": true
        }
      },
      {
        "tool": "recommend_skills",
        "arguments": { "query": "zzzz qqqq nonsense", "limit": 3, "token_budget": 60 },
        "expect": {
          "status": "ok",
          "uncertain": true,
          "recommendation_count": 0
        },
        "expect_selection_trace": {
          "tool": "recommend_skills",
          "query_intent": "recommendation",
          "requires_usage_event_id": true,
          "requires_abstention_reason": true
        }
      }
    ]
  },
  {
    "id": "JRN-04-execution-plan-tdd",
    "description": "Agent routes to execution guide for a known skill checklist request.",
    "server": "fixture",
    "tags": ["execution_plan"],
    "steps": [
      {
        "tool": "route_skill_query",
        "arguments": { "query": "How do I apply tdd-practice?" },
        "expect": {
          "status": "ok",
          "route": "execution_plan",
          "resolved_skill_id": "skill:tdd-practice",
          "suggested_tool": "get_skill_execution_guide"
        },
        "expect_selection_trace": {
          "tool": "route_skill_query",
          "query_intent": "execution_plan",
          "requires_usage_event_id": true,
          "requires_evidence": true
        }
      },
      {
        "tool": "get_skill_execution_guide",
        "arguments": { "skill_id": "skill:tdd-practice", "related_limit": 5 },
        "expect": {
          "status": "ok",
          "skill_id": "skill:tdd-practice",
          "requires_verification_checklist": true
        }
      }
    ]
  },
