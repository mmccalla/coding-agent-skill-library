    sh:targetClass skills:SkillVersion ;
    sh:sparql [
        sh:message "Direct partOfDomain edges must be backed by a matching BridgeAssertion." ;
        sh:select """
            PREFIX skills: <urn:coding-agent-skill-library:ontology:skills#>
