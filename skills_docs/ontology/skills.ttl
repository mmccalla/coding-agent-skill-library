@prefix skills: <urn:coding-agent-skill-library:ontology:skills#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

skills:Ontology a owl:Ontology ;
    rdfs:label "Coding Agent Skills Ontology" ;
    dcterms:description "Canonical semantic contract for a versioned, evidence-backed skills knowledge graph supporting KRAG." ;
    owl:imports <http://www.w3.org/2004/02/skos/core> ,
        <http://www.w3.org/ns/prov-o> .

skills:SkillPack a owl:Class ;
    rdfs:label "Skill pack" ;
    rdfs:comment "A governed pack boundary containing one or more canonical skills." .

skills:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A stable canonical skill identity across versions." .

skills:SkillVersion a owl:Class ;
    rdfs:label "Skill version" ;
    rdfs:comment "An immutable versioned snapshot of a skill's source-backed content." ;
    rdfs:subClassOf prov:Entity .

skills:IngestionRun a owl:Class ;
    rdfs:label "Ingestion run" ;
    rdfs:comment "A provenance activity that parses source resources and promotes semantic assertions." ;
    rdfs:subClassOf prov:Activity .

skills:SourceResource a owl:Class ;
    rdfs:label "Source resource" ;
    rdfs:comment "A versioned source file or other ingested resource." ;
    rdfs:subClassOf prov:Entity .

skills:ReferenceDocument a owl:Class ;
    rdfs:label "Reference document" ;
    rdfs:subClassOf skills:SourceResource ;
    rdfs:comment "A local source resource used as supporting reference material." .

skills:StructuralElement a owl:Class ;
    rdfs:label "Structural element" ;
    rdfs:comment "A typed structural fragment parsed from a source resource." ;
    rdfs:subClassOf prov:Entity .

skills:SkillSection a owl:Class ;
    rdfs:label "Skill section" ;
    rdfs:subClassOf skills:StructuralElement ;
    rdfs:comment "A markdown section within a versioned SKILL.md source." .

skills:EvidenceAnchor a owl:Class ;
    rdfs:label "Evidence anchor" ;
    rdfs:comment "The smallest stable evidence-bearing fragment promoted for retrieval or citation." ;
    rdfs:subClassOf prov:Entity .

skills:RetrievalUnit a owl:Class ;
    rdfs:label "Retrieval unit" ;
    rdfs:comment "A derived retrieval projection built from one or more evidence anchors." ;
    rdfs:subClassOf prov:Entity .

skills:Citation a owl:Class ;
    rdfs:label "Citation" ;
    rdfs:comment "An answer-time citation pointing to one or more evidence anchors." ;
    rdfs:subClassOf prov:Entity .

skills:SkillSelectionRun a owl:Class ;
    rdfs:label "Skill selection run" ;
    rdfs:comment "One invocation of the skill selector." ;
    rdfs:subClassOf prov:Activity .

skills:SkillSelectionRequest a owl:Class ;
    rdfs:label "Skill selection request" ;
    rdfs:comment "A normalized representation of the incoming task for one selection run." ;
    rdfs:subClassOf prov:Entity .

skills:SelectionCandidate a owl:Class ;
    rdfs:label "Selection candidate" ;
    rdfs:comment "A skill version considered during retrieval or reranking." ;
    rdfs:subClassOf prov:Entity .

skills:SkillSelectionDecision a owl:Class ;
    rdfs:label "Skill selection decision" ;
    rdfs:comment "A final selected or rejected skill decision." ;
    rdfs:subClassOf prov:Entity .

skills:ValidationRule a owl:Class ;
    rdfs:label "Validation rule" ;
    rdfs:comment "A structural, semantic or governance constraint." .

skills:MappingRule a owl:Class ;
    rdfs:label "Mapping rule" ;
    rdfs:comment "A governed rule used to promote semantic assertions from source evidence." .

skills:BridgeConcept a owl:Class ;
    rdfs:label "Bridge concept" ;
    rdfs:comment "A governed concept used in routing, retrieval and KRAG explanation." ;
    rdfs:subClassOf skos:Concept .

skills:SkillCategory a owl:Class ;
    rdfs:label "Skill category" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:TaskShape a owl:Class ;
    rdfs:label "Task shape" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:WorkflowStage a owl:Class ;
    rdfs:label "Workflow stage" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:Capability a owl:Class ;
    rdfs:label "Capability" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:ControlTheme a owl:Class ;
    rdfs:label "Control theme" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:KnowledgeDomain a owl:Class ;
    rdfs:label "Knowledge domain" ;
    rdfs:subClassOf skills:BridgeConcept .

skills:InvocationCondition a owl:Class ;
    rdfs:label "Invocation condition" ;
    rdfs:comment "A condition that narrows or excludes skill applicability." ;
    rdfs:subClassOf skos:Concept .

skills:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:comment "A governed tool or execution dependency required by a skill." ;
    rdfs:subClassOf skos:Concept .

skills:AgentRuntime a owl:Class ;
    rdfs:label "Agent runtime" ;
    rdfs:comment "A governed agent runtime or host profile." ;
    rdfs:subClassOf skos:Concept .

skills:SemanticAssertion a owl:Class ;
    rdfs:label "Semantic assertion" ;
    rdfs:comment "A provenance-bearing promoted semantic statement." ;
    rdfs:subClassOf prov:Entity .

skills:BridgeAssertion a owl:Class ;
    rdfs:label "Bridge assertion" ;
    rdfs:comment "A qualified assertion linking a skill version to a governed bridge concept." ;
    rdfs:subClassOf skills:SemanticAssertion .

skills:SkillDependencyAssertion a owl:Class ;
    rdfs:label "Skill dependency assertion" ;
    rdfs:comment "An evidence-backed assertion describing a version-aware dependency between skill versions." ;
    rdfs:subClassOf skills:SemanticAssertion .

skills:EvaluationDataset a owl:Class ;
    rdfs:label "Evaluation dataset" ;
    rdfs:comment "A versioned benchmark task set used to evaluate KRAG retrieval and selection quality." ;
    rdfs:subClassOf prov:Entity .

skills:EvaluationTask a owl:Class ;
    rdfs:label "Evaluation task" ;
    rdfs:comment "A representative benchmark task used to measure retrieval or selection quality." ;
    rdfs:subClassOf prov:Entity .

skills:ExpectedSkillVersion a owl:Class ;
    rdfs:label "Expected skill version" ;
    rdfs:comment "A ground-truth expected skill version attached to an evaluation task." ;
    rdfs:subClassOf prov:Entity .

skills:ObservedSelection a owl:Class ;
    rdfs:label "Observed selection" ;
    rdfs:comment "The skill version actually returned by the selector during an evaluation run." ;
    rdfs:subClassOf prov:Entity .

skills:EvaluationRun a owl:Class ;
    rdfs:label "Evaluation run" ;
    rdfs:comment "A reproducible execution of an evaluation task or dataset with metrics and outcomes." ;
    rdfs:subClassOf prov:Activity .

skills:FailureMode a owl:Class ;
    rdfs:label "Failure mode" ;
    rdfs:comment "A governed failure mode such as missed skill, wrong skill, stale skill, or over-selection." ;
    rdfs:subClassOf skos:Concept .

skills:SkillCategoryScheme a skos:ConceptScheme ;
    skos:prefLabel "Skill category scheme" .

skills:TaskShapeScheme a skos:ConceptScheme ;
    skos:prefLabel "Task shape scheme" .

skills:WorkflowStageScheme a skos:ConceptScheme ;
    skos:prefLabel "Workflow stage scheme" .

skills:CapabilityScheme a skos:ConceptScheme ;
    skos:prefLabel "Capability scheme" .

skills:ControlThemeScheme a skos:ConceptScheme ;
    skos:prefLabel "Control theme scheme" .

skills:KnowledgeDomainScheme a skos:ConceptScheme ;
    skos:prefLabel "Knowledge domain scheme" .

skills:InvocationConditionScheme a skos:ConceptScheme ;
    skos:prefLabel "Invocation condition scheme" .

skills:ToolScheme a skos:ConceptScheme ;
    skos:prefLabel "Tool scheme" .

skills:AgentRuntimeScheme a skos:ConceptScheme ;
    skos:prefLabel "Agent runtime scheme" .

skills:FailureModeScheme a skos:ConceptScheme ;
    skos:prefLabel "Failure mode scheme" .

skills:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "A stable local identifier or short canonical name." ;
    rdfs:range xsd:string .

skills:path a owl:DatatypeProperty ;
    rdfs:label "path" ;
    rdfs:comment "A repository-relative or governed canonical path." ;
    rdfs:range xsd:string .

skills:heading a owl:DatatypeProperty ;
    rdfs:label "heading" ;
    rdfs:comment "A source heading or section label." ;
    rdfs:domain skills:StructuralElement ;
    rdfs:range xsd:string .

skills:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:comment "Canonical text content used for evidence or retrieval projection." ;
    rdfs:range xsd:string .

skills:retrievalText a owl:DatatypeProperty ;
    rdfs:label "retrieval text" ;
    rdfs:comment "Normalized text used by retrieval, reranking and answer grounding." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:retrievalUnitType a owl:DatatypeProperty ;
    rdfs:label "retrieval unit type" ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:lexicalBoostTerms a owl:DatatypeProperty ;
    rdfs:label "lexical boost terms" ;
    rdfs:comment "Explicit lexical terms or phrases used to bias sparse retrieval." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:semanticAliases a owl:DatatypeProperty ;
    rdfs:label "semantic aliases" ;
    rdfs:comment "Alternate phrasings or synonyms that support semantic recall." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:priorityWeight a owl:DatatypeProperty ;
    rdfs:label "priority weight" ;
    rdfs:comment "Deterministic boost weight used before or during reranking." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:decimal .

skills:embeddingModel a owl:DatatypeProperty ;
    rdfs:label "embedding model" ;
    rdfs:comment "Embedding model identifier used for the retrieval projection, or an explicit placeholder when not embedded yet." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:embeddingVersion a owl:DatatypeProperty ;
    rdfs:label "embedding version" ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:vectorDimension a owl:DatatypeProperty ;
    rdfs:label "vector dimension" ;
    rdfs:comment "Configured embedding dimension, or zero when vectorization has not yet been applied." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:integer .

skills:retrievalProfile a owl:DatatypeProperty ;
    rdfs:label "retrieval profile" ;
    rdfs:comment "Named retrieval projection recipe used to construct the unit." ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range xsd:string .

skills:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash" ;
    rdfs:range xsd:string .

skills:checksum a owl:DatatypeProperty ;
    rdfs:label "checksum" ;
    rdfs:range xsd:string .

skills:versionIdentifier a owl:DatatypeProperty ;
    rdfs:label "version identifier" ;
    rdfs:range xsd:string .

skills:sourcePath a owl:DatatypeProperty ;
    rdfs:label "source path" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:string .

skills:headingPath a owl:DatatypeProperty ;
    rdfs:label "heading path" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:string .

skills:ordinal a owl:DatatypeProperty ;
    rdfs:label "ordinal" ;
    rdfs:range xsd:integer .

skills:lineStart a owl:DatatypeProperty ;
    rdfs:label "line start" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:integer .

skills:lineEnd a owl:DatatypeProperty ;
    rdfs:label "line end" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:integer .

skills:charStart a owl:DatatypeProperty ;
    rdfs:label "char start" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:integer .

skills:charEnd a owl:DatatypeProperty ;
    rdfs:label "char end" ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:integer .

skills:anchorRole a owl:DatatypeProperty ;
    rdfs:label "anchor role" ;
    rdfs:comment "The operational role of an evidence anchor, for example trigger, constraint, procedure, exclusion, example or reference." ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range xsd:string .

skills:wordCount a owl:DatatypeProperty ;
    rdfs:label "word count" ;
    rdfs:range xsd:integer .

skills:lineCount a owl:DatatypeProperty ;
    rdfs:label "line count" ;
    rdfs:range xsd:integer .

skills:isBaselineSkill a owl:DatatypeProperty ;
    rdfs:label "is baseline skill" ;
    rdfs:domain skills:Skill ;
    rdfs:range xsd:boolean .

skills:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:domain skills:SemanticAssertion ;
    rdfs:range xsd:decimal .

skills:selectionScore a owl:DatatypeProperty ;
    rdfs:label "selection score" ;
    rdfs:comment "A numeric score used during candidate ranking or final decision recording." ;
    rdfs:range xsd:decimal .

skills:selectionReason a owl:DatatypeProperty ;
    rdfs:label "selection reason" ;
    rdfs:domain skills:SkillSelectionDecision ;
    rdfs:range xsd:string .

skills:rejectionReason a owl:DatatypeProperty ;
    rdfs:label "rejection reason" ;
    rdfs:domain skills:SkillSelectionDecision ;
    rdfs:range xsd:string .

skills:requiresHumanApproval a owl:DatatypeProperty ;
    rdfs:label "requires human approval" ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range xsd:boolean .

skills:rationale a owl:DatatypeProperty ;
    rdfs:label "rationale" ;
    rdfs:comment "Human-readable justification for a promoted semantic assertion." ;
    rdfs:domain skills:SemanticAssertion ;
    rdfs:range xsd:string .

skills:dependencyType a owl:DatatypeProperty ;
    rdfs:label "dependency type" ;
    rdfs:comment "The operational dependency type between two skill versions." ;
    rdfs:domain skills:SkillDependencyAssertion ;
    rdfs:range xsd:string .

skills:precisionAt1 a owl:DatatypeProperty ;
    rdfs:label "precision at 1" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:recallAtK a owl:DatatypeProperty ;
    rdfs:label "recall at k" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:meanReciprocalRank a owl:DatatypeProperty ;
    rdfs:label "mean reciprocal rank" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:ndcgAtK a owl:DatatypeProperty ;
    rdfs:label "normalized discounted cumulative gain at k" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:graphLiftRecallAtK a owl:DatatypeProperty ;
    rdfs:label "graph lift recall at k" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:p95LatencyMs a owl:DatatypeProperty ;
    rdfs:label "p95 latency milliseconds" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:citationCoverage a owl:DatatypeProperty ;
    rdfs:label "citation coverage" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:exclusionAccuracy a owl:DatatypeProperty ;
    rdfs:label "exclusion accuracy" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:tokenCostPerSelection a owl:DatatypeProperty ;
    rdfs:label "token cost per selection" ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range xsd:decimal .

skills:source a owl:DatatypeProperty ;
    rdfs:label "legacy source note" ;
    rdfs:comment "Legacy projection-only source note. Canonical provenance should use prov:wasDerivedFrom." ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:range xsd:string .

skills:rule_id a owl:DatatypeProperty ;
    rdfs:label "legacy rule id" ;
    rdfs:comment "Legacy projection-only rule identifier. Canonical rule linkage should use usesMappingRule." ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:range xsd:string .

skills:source_scope a owl:DatatypeProperty ;
    rdfs:label "legacy source scope" ;
    rdfs:comment "Legacy projection-only source scope." ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:range xsd:string .

skills:source_ref a owl:DatatypeProperty ;
    rdfs:label "legacy source ref" ;
    rdfs:comment "Legacy projection-only source reference." ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:range xsd:string .

skills:containsSkill a owl:ObjectProperty ;
    rdfs:domain skills:SkillPack ;
    rdfs:range skills:Skill .

skills:hasVersion a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:SkillVersion ;
    owl:inverseOf skills:versionOf .

skills:currentVersion a owl:ObjectProperty ;
    a owl:FunctionalProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:SkillVersion .

skills:versionOf a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:Skill .

skills:belongsToCategory a owl:ObjectProperty ;
    a owl:FunctionalProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:SkillCategory .

skills:hasSourceResource a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:SourceResource .

skills:hasSection a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:SkillSection .

skills:hasStructuralElement a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:StructuralElement .

skills:hasEvidenceAnchor a owl:ObjectProperty ;
    rdfs:domain skills:StructuralElement ;
    rdfs:range skills:EvidenceAnchor .

skills:derivedFromElement a owl:ObjectProperty ;
    rdfs:domain skills:EvidenceAnchor ;
    rdfs:range skills:StructuralElement .

skills:projectsFrom a owl:ObjectProperty ;
    rdfs:domain skills:RetrievalUnit ;
    rdfs:range skills:EvidenceAnchor .

skills:citesEvidence a owl:ObjectProperty ;
    rdfs:domain skills:Citation ;
    rdfs:range skills:EvidenceAnchor .

skills:hasSelectionRequest a owl:ObjectProperty ;
    rdfs:domain skills:SkillSelectionRun ;
    rdfs:range skills:SkillSelectionRequest .

skills:hasSelectionCandidate a owl:ObjectProperty ;
    rdfs:domain skills:SkillSelectionRun ;
    rdfs:range skills:SelectionCandidate .

skills:hasSelectionDecision a owl:ObjectProperty ;
    rdfs:domain skills:SkillSelectionRun ;
    rdfs:range skills:SkillSelectionDecision .

skills:hasEvaluationTask a owl:ObjectProperty ;
    rdfs:domain skills:EvaluationDataset ;
    rdfs:range skills:EvaluationTask .

skills:evaluatedDataset a owl:ObjectProperty ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range skills:EvaluationDataset .

skills:expectsSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:EvaluationTask ;
    rdfs:range skills:ExpectedSkillVersion .

skills:expectedSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:ExpectedSkillVersion ;
    rdfs:range skills:SkillVersion .

skills:observedSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:ObservedSelection ;
    rdfs:range skills:SkillVersion .

skills:evaluatedTask a owl:ObjectProperty ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range skills:EvaluationTask .

skills:recordedSelection a owl:ObjectProperty ;
    rdfs:domain skills:EvaluationRun ;
    rdfs:range skills:ObservedSelection .

skills:hasFailureMode a owl:ObjectProperty ;
    rdfs:domain skills:ObservedSelection ;
    rdfs:range skills:FailureMode .

skills:candidateSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:SelectionCandidate ;
    rdfs:range skills:SkillVersion .

skills:selectedSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:SkillSelectionDecision ;
    rdfs:range skills:SkillVersion .

skills:rejectedSkillVersion a owl:ObjectProperty ;
    rdfs:domain skills:SkillSelectionDecision ;
    rdfs:range skills:SkillVersion .

skills:selectionSupportedBy a owl:ObjectProperty ;
    rdfs:comment "Evidence anchors supporting a candidate ranking or final decision." ;
    rdfs:range skills:EvidenceAnchor .

skills:validatedBy a owl:ObjectProperty ;
    rdfs:range skills:ValidationRule .

skills:assertionFor a owl:ObjectProperty ;
    a owl:FunctionalProperty ;
    rdfs:domain skills:SemanticAssertion ;
    rdfs:range skills:SkillVersion .

skills:bridgeTarget a owl:ObjectProperty ;
    rdfs:domain skills:BridgeAssertion ;
    rdfs:range skills:BridgeConcept .

skills:supportedBy a owl:ObjectProperty ;
    rdfs:domain skills:SemanticAssertion ;
    rdfs:range skills:EvidenceAnchor .

skills:usesMappingRule a owl:ObjectProperty ;
    rdfs:domain skills:SemanticAssertion ;
    rdfs:range skills:MappingRule .

skills:dependencySourceVersion a owl:ObjectProperty ;
    rdfs:domain skills:SkillDependencyAssertion ;
    rdfs:range skills:SkillVersion .

skills:dependencyTargetVersion a owl:ObjectProperty ;
    rdfs:domain skills:SkillDependencyAssertion ;
    rdfs:range skills:SkillVersion .

skills:supportsTaskShape a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:TaskShape .

skills:operatesInStage a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:WorkflowStage .

skills:enablesCapability a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:Capability .

skills:governedBy a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:ControlTheme .

skills:partOfDomain a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:KnowledgeDomain .

skills:notForTaskShape a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:TaskShape .

skills:excludedWhen a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:InvocationCondition .

skills:requiresTool a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:Tool .

skills:incompatibleWithTool a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:Tool .

skills:compatibleWithRuntime a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:AgentRuntime .

skills:incompatibleWithRuntime a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:AgentRuntime .

skills:supersededBy a owl:ObjectProperty ;
    rdfs:domain skills:SkillVersion ;
    rdfs:range skills:SkillVersion .

skills:precedes a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .

skills:requires a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .

skills:complements a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .

skills:refines a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .

skills:governsSkill a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .

skills:validatesSkill a owl:ObjectProperty ;
    rdfs:domain skills:Skill ;
    rdfs:range skills:Skill .
